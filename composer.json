{
    "name": "simplesamlphp/simplesamlphp-module-consentsimpleadmin",
    "description": "A SimpleSAMLphp module implementing a very simple user interface for managing consent.",
    "type": "simplesamlphp-module",
    "homepage": "http://simplesamlphp.org",
    "license": "LGPL-2.1",
    "authors": [
        {
            "name": "Olav Morken",
            "email": "olav.morken@uninett.no"
        },
        {
            "name": "Andreas Åkre Solberg",
            "email": "andreas.solberg@uninett.no"
        }
    ],
    "extra": {
        "ssp-mixedcase-module-name": "consentSimpleAdmin"
    },
    "autoload": {
        "psr-4": {
            "SimpleSAML\\Module\\consentSimpleAdmin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SimpleSAML\\Module\\consent\\": "vendor/simplesamlphp/simplesamlphp/modules/consent/src",
            "SimpleSAML\\Test\\Utils\\": "vendor/simplesamlphp/simplesamlphp/tests/Utils"
        }
    },
    "require": {
        "php": "^8.3",
        "simplesamlphp/composer-module-installer": "~1.7.0",
        "simplesamlphp/simplesamlphp": "~2.5@dev",
        "simplesamlphp/simplesamlphp-module-consent": "~1.5",
        "symfony/http-foundation": "^7.4"
    },
    "require-dev": {
        "simplesamlphp/simplesamlphp-test-framework": "~1.11"
    },
    "config": {
        "preferred-install": {
            "simplesamlphp/simplesamlphp": "source",
            "*": "dist"
        },
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "simplesamlphp/composer-module-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "simplesamlphp/composer-xmlprovider-installer": true
        }
    }
}
